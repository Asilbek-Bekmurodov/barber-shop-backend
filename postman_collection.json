{
  "info": {
    "name": "Barbershop Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://barber-shop-backend-zoxv.onrender.com" },
    { "key": "token", "value": "" },
    { "key": "barberId", "value": "" },
    { "key": "serviceId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "uploadUrl", "value": "" },
    { "key": "uploadKey", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Secret123!\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Secret123!\"\n}"
        }
      }
    },
    {
      "name": "Barbers - List",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/barbers"
      }
    },
    {
      "name": "Barbers - Create",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/barbers",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Aziz\",\n  \"phone\": \"+998901234567\",\n  \"experience\": 5,\n  \"speciality\": \"Fade\",\n  \"rating\": 4.8,\n  \"workingHours\": {\n    \"start\": \"09:00\",\n    \"end\": \"18:00\"\n  },\n  \"daysOff\": [\"sunday\"]\n}"
        }
      }
    },
    {
      "name": "Barbers - Upload Photo",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/barbers/{{barberId}}/photo",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "image", "type": "file", "src": "" }
          ]
        }
      }
    },
    {
      "name": "Barbers - Services List",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/barbers/{{barberId}}/services"
      }
    },
    {
      "name": "Barbers - Service Create",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/barbers/{{barberId}}/services",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Haircut\",\n  \"price\": 50000,\n  \"duration\": 30,\n  \"description\": \"Classic haircut service\"\n}"
        }
      }
    },
    {
      "name": "Barbers - Service Update",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/barbers/{{barberId}}/services/{{serviceId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Premium Haircut\",\n  \"price\": 70000,\n  \"duration\": 45,\n  \"description\": \"Updated service\"\n}"
        }
      }
    },
    {
      "name": "Barbers - Service Delete",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/barbers/{{barberId}}/services/{{serviceId}}"
      }
    },
    {
      "name": "Barbers - Availability",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/barbers/{{barberId}}/availability?date=2026-03-20&slotMinutes=30"
      }
    },
    {
      "name": "Services - List",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/services"
      }
    },
    {
      "name": "Services - Create",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/services",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"barberId\": \"{{barberId}}\",\n  \"title\": \"Beard Trim\",\n  \"price\": 30000,\n  \"duration\": 20,\n  \"description\": \"Beard styling\"\n}"
        }
      }
    },
    {
      "name": "Services - Update",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/services/{{serviceId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Beard Trim Deluxe\",\n  \"price\": 40000,\n  \"duration\": 25,\n  \"description\": \"Updated beard styling\"\n}"
        }
      }
    },
    {
      "name": "Services - Delete",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/services/{{serviceId}}"
      }
    },
    {
      "name": "Bookings - List",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/bookings"
      }
    },
    {
      "name": "Bookings - Create",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/bookings",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"barberId\": \"{{barberId}}\",\n  \"date\": \"2026-03-20\",\n  \"startTime\": \"14:00\",\n  \"status\": \"pending\"\n}"
        }
      }
    },
    {
      "name": "Bookings - Update",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/bookings/{{bookingId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"confirmed\",\n  \"startTime\": \"15:00\"\n}"
        }
      }
    },
    {
      "name": "Bookings - Delete",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/bookings/{{bookingId}}"
      }
    },
    {
      "name": "Reviews - Create",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/reviews",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"barberId\": \"{{barberId}}\",\n  \"rating\": 5,\n  \"comment\": \"Zo'r xizmat!\"\n}"
        }
      }
    },
    {
      "name": "Reviews - By Barber",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/reviews/barber/{{barberId}}"
      }
    },
    {
      "name": "Admin - Dashboard",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/admin/dashboard"
      }
    },
    {
      "name": "Users - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/users",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ali Valiyev\",\n  \"email\": \"ali@example.com\",\n  \"password\": \"Secret123!\",\n  \"role\": \"client\",\n  \"phone\": \"+998901112233\"\n}"
        }
      }
    },
    {
      "name": "Users - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/users"
      }
    },
    {
      "name": "Users - Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/users/{{userId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ali Updated\",\n  \"phone\": \"+998909998877\",\n  \"role\": \"barber\"\n}"
        }
      }
    },
    {
      "name": "Users - Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/users/{{userId}}"
      }
    },
    {
      "name": "Users - Upload Photo",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/users/{{userId}}/photo",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "image", "type": "file", "src": "" }
          ]
        }
      }
    },
    {
      "name": "Upload - Image",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/upload",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "image", "type": "file", "src": "" }
          ]
        }
      }
    },
    {
      "name": "Upload - Delete",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/upload",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"{{uploadUrl}}\"\n}"
        }
      }
    }
  ]
}
